@startuml
title <size:24>Container View: Workshop Live Interaction Tool</size>\n<size:24>Current runtime containers.</size>

set separator none
left to right direction

<style>
  root {
    BackgroundColor: #ffffff
    FontColor: #444444
  }
</style>

!include <C4/C4>
!include <C4/C4_Context>
!include <C4/C4_Container>

Person(Host, "Host", $descr="Runs the workshop, controls activities, and monitors the live session.", $tags="", $link="")
Person(Participant, "Participant", $descr="Joins from a browser, votes, reacts, uploads, and follows the session.", $tags="", $link="")
System(AnthropicClaudeAPI, "Anthropic Claude API", $descr="LLM used by the daemon for debate AI cleanup and code-review smart paste extraction.", $tags="", $link="")
System(victormacosaddons, "victor-macos-addons", $descr="Local Mac bridge that emits slide events and receives emoji/session notifications.", $tags="", $link="")
System(Nominatim, "Nominatim", $descr="Reverse geocodes GPS coordinates into city and country.", $tags="", $link="")
System(GoogleDrive, "Google Drive", $descr="Hosts exported slide PDFs consumed by the Railway cache.", $tags="", $link="")
System(AgentMail, "AgentMail", $descr="Hosted inbox/email service: delivers participant feedback notifications and routes incoming Claude email webhooks.", $tags="", $link="")
System(Hostsessionfiles, "Host session files", $descr="Session folders, normalized transcripts, ai-summary.md, uploaded files, and slide manifests on the trainer's Mac.", $tags="", $link="")
System(LocalChromaDBstore, "Local ChromaDB store", $descr="~/.workshop-rag/chroma — background-indexed local materials.", $tags="", $link="")

System_Boundary("WorkshopLiveInteractionTool_boundary", "Workshop Live Interaction Tool", $tags="") {
  Container(WorkshopLiveInteractionTool.ParticipantSPA, "Participant SPA", $techn="HTML/CSS/JavaScript", $descr="Participant-facing UI served from Railway session routes.", $tags="", $link="")
  Container(WorkshopLiveInteractionTool.HostSPA, "Host SPA", $techn="HTML/CSS/JavaScript", $descr="Host control panel served from the daemon host server on localhost.", $tags="", $link="")
  Container(WorkshopLiveInteractionTool.RailwayBackend, "Railway Backend", $techn="Python 3.12 / FastAPI / Uvicorn", $descr="Thin session-aware bridge for participants, slides, uploads, daemon sync, inbox webhooks, and telemetry.", $tags="", $link="")
  Container(WorkshopLiveInteractionTool.TrainingDaemon, "Training Daemon", $techn="Python 3.12 CLI + embedded FastAPI", $descr="Local source of truth for host control, live state, persistence, and AI-assisted jobs.", $tags="", $link="")
}

Rel(Participant, WorkshopLiveInteractionTool.ParticipantSPA, "Uses in browser", $techn="", $tags="", $link="")
Rel(Host, WorkshopLiveInteractionTool.HostSPA, "Uses in browser", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.ParticipantSPA, WorkshopLiveInteractionTool.RailwayBackend, "Calls session-scoped REST and WebSocket APIs", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.ParticipantSPA, Nominatim, "Reverse geocodes optional location", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.HostSPA, WorkshopLiveInteractionTool.TrainingDaemon, "Calls host REST and proxied WebSocket APIs on localhost", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon, WorkshopLiveInteractionTool.RailwayBackend, "Synchronizes active session, participant events, uploads, and generated static assets", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon, AnthropicClaudeAPI, "Requests debate cleanup and code-review smart-paste extraction", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon, victormacosaddons, "Receives slide events and sends emoji/session notifications", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon, AgentMail, "Sends best-effort email notifications via AgentMail SDK", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon, Hostsessionfiles, "Reads and writes session folders, transcripts, and summary files", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon, LocalChromaDBstore, "Indexes local materials in the background", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.RailwayBackend, GoogleDrive, "Downloads slide PDFs into cache", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.RailwayBackend, AgentMail, "Receives signed AgentMail webhooks for incoming Claude email", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.RailwayBackend, WorkshopLiveInteractionTool.TrainingDaemon, "Configures OTel tracing and FastAPI instrumentation through (Railway side)", $techn="", $tags="", $link="")

SHOW_LEGEND(true)
hide stereotypes
@enduml