@startuml
title <size:24>System Context View: Workshop Live Interaction Tool</size>\n<size:24>Overall system context.</size>

set separator none
left to right direction

<style>
  root {
    BackgroundColor: #ffffff
    FontColor: #444444
  }
</style>

!include <C4/C4>
!include <C4/C4_Context>

Person(Host, "Host", $descr="Runs the workshop, controls activities, and monitors the live session.", $tags="", $link="")
System(WorkshopLiveInteractionTool, "Workshop Live Interaction Tool", $descr="Self-hosted real-time audience interaction platform.", $tags="", $link="")
Person(Participant, "Participant", $descr="Joins from a browser, votes, reacts, uploads, and follows the session.", $tags="", $link="")
System(AnthropicClaudeAPI, "Anthropic Claude API", $descr="LLM used by the daemon for debate AI cleanup and code-review smart paste extraction.", $tags="", $link="")
System(victormacosaddons, "victor-macos-addons", $descr="Local Mac bridge that emits slide events and receives emoji/session notifications.", $tags="", $link="")
System(Nominatim, "Nominatim", $descr="Reverse geocodes GPS coordinates into city and country.", $tags="", $link="")
System(GoogleDrive, "Google Drive", $descr="Hosts exported slide PDFs consumed by the Railway cache.", $tags="", $link="")
System(AgentMail, "AgentMail", $descr="Hosted inbox/email service: delivers participant feedback notifications and routes incoming Claude email webhooks.", $tags="", $link="")
System(Hostsessionfiles, "Host session files", $descr="Session folders, normalized transcripts, ai-summary.md, uploaded files, and slide manifests on the trainer's Mac.", $tags="", $link="")
System(LocalChromaDBstore, "Local ChromaDB store", $descr="~/.workshop-rag/chroma — background-indexed local materials.", $tags="", $link="")

Rel(Participant, WorkshopLiveInteractionTool, "Uses in browser", $techn="", $tags="", $link="")
Rel(Host, WorkshopLiveInteractionTool, "Uses in browser", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool, Nominatim, "Reverse geocodes optional location", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool, AnthropicClaudeAPI, "Requests debate cleanup and code-review smart-paste extraction", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool, victormacosaddons, "Receives slide events and sends emoji/session notifications", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool, AgentMail, "Sends best-effort email notifications via AgentMail SDK", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool, Hostsessionfiles, "Reads and writes session folders, transcripts, and summary files", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool, LocalChromaDBstore, "Indexes local materials in the background", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool, GoogleDrive, "Downloads slide PDFs into cache", $techn="", $tags="", $link="")

SHOW_LEGEND(true)
hide stereotypes
@enduml