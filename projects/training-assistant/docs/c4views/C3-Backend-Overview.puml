@startuml
title <size:24>Component View: Workshop Live Interaction Tool - Railway Backend</size>\n<size:24>Main Railway backend subsystems present in the repository.</size>

set separator none
left to right direction

<style>
  root {
    BackgroundColor: #ffffff
    FontColor: #444444
  }
</style>

!include <C4/C4>
!include <C4/C4_Context>
!include <C4/C4_Container>
!include <C4/C4_Component>

System_Boundary("WorkshopLiveInteractionTool_boundary", "Workshop Live Interaction Tool", $tags="") {
  Container_Boundary("WorkshopLiveInteractionTool.RailwayBackend_boundary", "Railway Backend", $tags="") {
    Component(WorkshopLiveInteractionTool.RailwayBackend.Bootstrap, "Bootstrap", $techn="railway/app.py", $descr="Registers route ordering, OTel instrumentation, session guards, and startup stamping (version.js / deploy-info.json).", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.RailwayBackend.SharedCore, "Shared Core", $techn="railway/shared/*", $descr="AppState, auth, session registry/guard, throttling, metrics, messaging, and version helpers.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.RailwayBackend.WebSocketbridge, "WebSocket bridge", $techn="railway/features/ws/*", $descr="Daemon auth, session-scoped browser sockets, participant proxy bridge, and broadcast fan-out.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.RailwayBackend.Pageroutes, "Page routes", $techn="railway/features/pages/router.py", $descr="Landing, participant, and host static page routing.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.RailwayBackend.Slidescacheandfileserving, "Slides cache and file serving", $techn="railway/features/slides/*", $descr="Public slide catalog/current slide, Google Drive cache, and host upload/invalidate helpers.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.RailwayBackend.Temporaryuploadbridge, "Temporary upload bridge", $techn="railway/features/upload/*", $descr="Streams participant uploads into temporary storage and lets the daemon fetch and acknowledge them.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.RailwayBackend.Staticsyncendpoints, "Static sync endpoints", $techn="railway/features/internal/router.py", $descr="Allows the daemon to upload and delete generated files under static/.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.RailwayBackend.Inboxwebhookbridge, "Inbox webhook bridge", $techn="railway/features/inbox/router.py", $descr="Verifies AgentMail (Svix) webhooks for incoming Claude email and forwards events to the connected claude-inbox WebSocket listener.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.RailwayBackend.Telemetryreceiver, "Telemetry receiver", $techn="railway/features/telemetry/router.py", $descr="Receives browser OTel spans (POST /api/telemetry/spans) and appends them to the shared traces file.", $tags="", $link="")
  }

  Container(WorkshopLiveInteractionTool.ParticipantSPA, "Participant SPA", $techn="HTML/CSS/JavaScript", $descr="Participant-facing UI served from Railway session routes.", $tags="", $link="")
  Container(WorkshopLiveInteractionTool.TrainingDaemon, "Training Daemon", $techn="Python 3.12 CLI + embedded FastAPI", $descr="Local source of truth for host control, live state, persistence, and AI-assisted jobs.", $tags="", $link="")
}

Rel(WorkshopLiveInteractionTool.ParticipantSPA, WorkshopLiveInteractionTool.RailwayBackend.Pageroutes, "Loads participant pages", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.ParticipantSPA, WorkshopLiveInteractionTool.RailwayBackend.WebSocketbridge, "Connects as participant and forwards REST commands via the daemon proxy", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.ParticipantSPA, WorkshopLiveInteractionTool.RailwayBackend.Slidescacheandfileserving, "Reads slides and downloads PDFs", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.ParticipantSPA, WorkshopLiveInteractionTool.RailwayBackend.Temporaryuploadbridge, "Uploads participant files", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.ParticipantSPA, WorkshopLiveInteractionTool.RailwayBackend.Telemetryreceiver, "Posts browser OTel spans (test/diagnostic mode)", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.RailwayBackend.Bootstrap, WorkshopLiveInteractionTool.RailwayBackend.SharedCore, "Initializes", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.RailwayBackend.Bootstrap, WorkshopLiveInteractionTool.RailwayBackend.WebSocketbridge, "Registers", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.RailwayBackend.Bootstrap, WorkshopLiveInteractionTool.RailwayBackend.Pageroutes, "Registers", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.RailwayBackend.Bootstrap, WorkshopLiveInteractionTool.RailwayBackend.Slidescacheandfileserving, "Registers", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.RailwayBackend.Bootstrap, WorkshopLiveInteractionTool.RailwayBackend.Temporaryuploadbridge, "Registers", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.RailwayBackend.Bootstrap, WorkshopLiveInteractionTool.RailwayBackend.Staticsyncendpoints, "Registers", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.RailwayBackend.Bootstrap, WorkshopLiveInteractionTool.RailwayBackend.Inboxwebhookbridge, "Registers", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.RailwayBackend.Bootstrap, WorkshopLiveInteractionTool.RailwayBackend.Telemetryreceiver, "Registers when OTEL_TRACES_FILE is set", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.RailwayBackend.WebSocketbridge, WorkshopLiveInteractionTool.RailwayBackend.SharedCore, "Reads auth, session, and connection state from", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.RailwayBackend.Pageroutes, WorkshopLiveInteractionTool.RailwayBackend.SharedCore, "Uses auth/session helpers from", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.RailwayBackend.Slidescacheandfileserving, WorkshopLiveInteractionTool.RailwayBackend.SharedCore, "Reads slide/current-session state from", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.RailwayBackend.Slidescacheandfileserving, WorkshopLiveInteractionTool.RailwayBackend.WebSocketbridge, "Uses daemon proxy and download protocol from", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.RailwayBackend.Temporaryuploadbridge, WorkshopLiveInteractionTool.RailwayBackend.SharedCore, "Associates uploads with active participants from", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.RailwayBackend.Temporaryuploadbridge, WorkshopLiveInteractionTool.RailwayBackend.WebSocketbridge, "Uses daemon protocol helpers from", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.RailwayBackend.Staticsyncendpoints, WorkshopLiveInteractionTool.RailwayBackend.SharedCore, "Uses host auth from", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.RailwayBackend.Inboxwebhookbridge, WorkshopLiveInteractionTool.RailwayBackend.SharedCore, "Stores the connected claude-inbox WebSocket on", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.RailwayBackend.WebSocketbridge, WorkshopLiveInteractionTool.RailwayBackend.Slidescacheandfileserving, "Triggers slide cache downloads and broadcasts through", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.RailwayBackend.Bootstrap, WorkshopLiveInteractionTool.TrainingDaemon, "Configures OTel tracing and FastAPI instrumentation through (Railway side)", $techn="", $tags="", $link="")

SHOW_LEGEND(true)
hide stereotypes
@enduml