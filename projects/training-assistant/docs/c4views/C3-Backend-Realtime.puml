@startuml
title <size:24>Component View: Workshop Live Interaction Tool - Railway Backend</size>\n<size:24>Session-aware browser and daemon bridge slice.</size>

set separator none
left to right direction

<style>
  root {
    BackgroundColor: #ffffff
    FontColor: #444444
  }
</style>

!include <C4/C4>
!include <C4/C4_Context>
!include <C4/C4_Container>
!include <C4/C4_Component>

System_Boundary("WorkshopLiveInteractionTool_boundary", "Workshop Live Interaction Tool", $tags="") {
  Container_Boundary("WorkshopLiveInteractionTool.RailwayBackend_boundary", "Railway Backend", $tags="") {
    Component(WorkshopLiveInteractionTool.RailwayBackend.Bootstrap, "Bootstrap", $techn="railway/app.py", $descr="Registers route ordering, OTel instrumentation, session guards, and startup stamping (version.js / deploy-info.json).", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.RailwayBackend.SharedCore, "Shared Core", $techn="railway/shared/*", $descr="AppState, auth, session registry/guard, throttling, metrics, messaging, and version helpers.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.RailwayBackend.WebSocketbridge, "WebSocket bridge", $techn="railway/features/ws/*", $descr="Daemon auth, session-scoped browser sockets, participant proxy bridge, and broadcast fan-out.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.RailwayBackend.Pageroutes, "Page routes", $techn="railway/features/pages/router.py", $descr="Landing, participant, and host static page routing.", $tags="", $link="")
  }

  Container(WorkshopLiveInteractionTool.ParticipantSPA, "Participant SPA", $techn="HTML/CSS/JavaScript", $descr="Participant-facing UI served from Railway session routes.", $tags="", $link="")
  Container(WorkshopLiveInteractionTool.HostSPA, "Host SPA", $techn="HTML/CSS/JavaScript", $descr="Host control panel served from the daemon host server on localhost.", $tags="", $link="")
  Container(WorkshopLiveInteractionTool.TrainingDaemon, "Training Daemon", $techn="Python 3.12 CLI + embedded FastAPI", $descr="Local source of truth for host control, live state, persistence, and AI-assisted jobs.", $tags="", $link="")
}

Rel(WorkshopLiveInteractionTool.HostSPA, WorkshopLiveInteractionTool.TrainingDaemon, "Calls host REST and proxied WebSocket APIs on localhost", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.ParticipantSPA, WorkshopLiveInteractionTool.RailwayBackend.Pageroutes, "Loads participant pages", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.ParticipantSPA, WorkshopLiveInteractionTool.RailwayBackend.WebSocketbridge, "Connects as participant and forwards REST commands via the daemon proxy", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.RailwayBackend.Bootstrap, WorkshopLiveInteractionTool.RailwayBackend.SharedCore, "Initializes", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.RailwayBackend.Bootstrap, WorkshopLiveInteractionTool.RailwayBackend.WebSocketbridge, "Registers", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.RailwayBackend.Bootstrap, WorkshopLiveInteractionTool.RailwayBackend.Pageroutes, "Registers", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.RailwayBackend.WebSocketbridge, WorkshopLiveInteractionTool.RailwayBackend.SharedCore, "Reads auth, session, and connection state from", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.RailwayBackend.Pageroutes, WorkshopLiveInteractionTool.RailwayBackend.SharedCore, "Uses auth/session helpers from", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.RailwayBackend.Bootstrap, WorkshopLiveInteractionTool.TrainingDaemon, "Configures OTel tracing and FastAPI instrumentation through (Railway side)", $techn="", $tags="", $link="")

SHOW_LEGEND(true)
hide stereotypes
@enduml