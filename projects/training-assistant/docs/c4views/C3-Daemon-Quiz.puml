@startuml
title <size:24>Component View: Workshop Live Interaction Tool - Training Daemon</size>\n<size:24>Daemon slice for quiz generation and refinement.</size>

set separator none
left to right direction

<style>
  root {
    BackgroundColor: #ffffff
    FontColor: #444444
  }
</style>

!include <C4/C4>
!include <C4/C4_Context>
!include <C4/C4_Component>

System(AnthropicClaudeAPI, "Anthropic Claude API", $descr="LLM used by the daemon for quiz generation/refinement and debate cleanup.", $tags="", $link="")
System(Hostsessionfiles, "Host session files", $descr="Session folders, normalized transcripts, ai-summary.md, uploaded files, and slide manifests on the trainer's Mac.", $tags="", $link="")
System(LocalChromaDBstore, "Local ChromaDB store", $descr="~/.workshop-rag/chroma", $tags="", $link="")

System_Boundary("WorkshopLiveInteractionTool_boundary", "Workshop Live Interaction Tool", $tags="") {
  Container_Boundary("WorkshopLiveInteractionTool.TrainingDaemon_boundary", "Training Daemon", $tags="") {
    Component(WorkshopLiveInteractionTool.TrainingDaemon.HostAPIs, "Host APIs", $techn="daemon/session/router.py + daemon/activity/router.py + daemon/quiz/router.py + daemon/leaderboard/router.py + daemon/host_state_router.py + daemon/misc/router.py + daemon/poll/router.py + daemon/qa/router.py + daemon/debate/router.py + daemon/codereview/router.py + daemon/wordcloud/router.py", $descr="Local host-side routers for session lifecycle, activity switching, quiz requests, leaderboard control, host state, uploads, and feature administration.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.TrainingDaemon.Railwaybridge, "Railway bridge", $techn="daemon/ws_client.py + daemon/proxy_handler.py + daemon/ws_publish.py + daemon/upload.py + daemon/static_sync.py", $descr="Persistent /ws/daemon client, proxy response handling, typed broadcasts, upload handoff, and static sync.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.TrainingDaemon.Sessionpersistence, "Session persistence", $techn="daemon/session_state.py + daemon/persisted_models.py", $descr="Persists global-state.json, session-state.json, session metadata, key points, and slide manifests.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.TrainingDaemon.Quizpipeline, "Quiz pipeline", $techn="daemon/quiz/* + daemon/llm/adapter.py + daemon/rag/*", $descr="Generates and refines quiz suggestions from notes, key points, transcripts, and local materials.", $tags="", $link="")
  }

}

Rel(WorkshopLiveInteractionTool.TrainingDaemon.Quizpipeline, AnthropicClaudeAPI, "Requests quiz drafts and refinements from", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.Quizpipeline, WorkshopLiveInteractionTool.TrainingDaemon.Railwaybridge, "Publishes quiz status through", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.HostAPIs, WorkshopLiveInteractionTool.TrainingDaemon.Railwaybridge, "Publishes host-driven updates through", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.HostAPIs, WorkshopLiveInteractionTool.TrainingDaemon.Sessionpersistence, "Persists and restores session files through", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.HostAPIs, WorkshopLiveInteractionTool.TrainingDaemon.Quizpipeline, "Triggers", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.Railwaybridge, WorkshopLiveInteractionTool.TrainingDaemon.Sessionpersistence, "Reads session metadata for sync payloads from", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.Quizpipeline, Hostsessionfiles, "Reads notes, transcripts, and local materials from", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.Quizpipeline, LocalChromaDBstore, "Retrieves indexed local context from", $techn="", $tags="", $link="")

SHOW_LEGEND(true)
hide stereotypes
@enduml