@startuml
title <size:24>Component View: Workshop Live Interaction Tool - Training Daemon</size>\n<size:24>Main daemon subsystems aligned to the daemon-first runtime.</size>

set separator none
left to right direction

<style>
  root {
    BackgroundColor: #ffffff
    FontColor: #444444
  }
</style>

!include <C4/C4>
!include <C4/C4_Context>
!include <C4/C4_Container>
!include <C4/C4_Component>

System(AnthropicClaudeAPI, "Anthropic Claude API", $descr="LLM used by the daemon for debate AI cleanup and code-review smart paste extraction.", $tags="", $link="")
System(victormacosaddons, "victor-macos-addons", $descr="Local Mac bridge that emits slide events and receives emoji/session notifications.", $tags="", $link="")
System(AgentMail, "AgentMail", $descr="Hosted inbox/email service: delivers participant feedback notifications and routes incoming Claude email webhooks.", $tags="", $link="")
System(Hostsessionfiles, "Host session files", $descr="Session folders, normalized transcripts, ai-summary.md, uploaded files, and slide manifests on the trainer's Mac.", $tags="", $link="")
System(LocalChromaDBstore, "Local ChromaDB store", $descr="~/.workshop-rag/chroma — background-indexed local materials.", $tags="", $link="")

System_Boundary("WorkshopLiveInteractionTool_boundary", "Workshop Live Interaction Tool", $tags="") {
  Container_Boundary("WorkshopLiveInteractionTool.TrainingDaemon_boundary", "Training Daemon", $tags="") {
    Component(WorkshopLiveInteractionTool.TrainingDaemon.Embeddedhostserver, "Embedded host server", $techn="daemon/host_server.py + daemon/host_proxy.py + daemon/host_ws.py", $descr="Serves /host on localhost:1234, mounts local feature routers, holds the host-browser WS, and reverse-proxies remaining HTTP/WS traffic to Railway.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.TrainingDaemon.ParticipantAPIs, "Participant APIs", $techn="daemon/participant/router.py + daemon/poll/router.py + daemon/qa/router.py + daemon/debate/router.py + daemon/codereview/router.py + daemon/misc/router.py + daemon/slides/router.py + daemon/emoji/router.py + daemon/wordcloud/router.py", $descr="Authoritative participant REST handlers for identity, polls, Q&A, debate, code review, misc actions, slides, emoji, and word cloud.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.TrainingDaemon.HostAPIs, "Host APIs", $techn="daemon/session/router.py + daemon/activity/router.py + daemon/leaderboard/router.py + daemon/host_state_router.py + daemon/quiz/queue_router.py + daemon/{poll,qa,debate,codereview,wordcloud,misc}/router.py (host sub-routers)", $descr="Local host-side routers for session lifecycle, activity switching, leaderboard, host state snapshot, poll queue, and per-feature host actions.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.TrainingDaemon.Runtimestatemodules, "Runtime state modules", $techn="daemon/*/state.py + daemon/scores.py + daemon/session/state.py", $descr="In-memory feature state for participants, polls, Q&A, debate, code review, misc data, leaderboard, scores, session stack, and word cloud.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.TrainingDaemon.Pollqueue, "Poll queue", $techn="daemon/quiz/queue.py + daemon/quiz/queue_router.py", $descr="In-memory queue of pre-submitted poll questions for one-at-a-time firing by the host.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.TrainingDaemon.Railwaybridge, "Railway bridge", $techn="daemon/ws_client.py + daemon/proxy_handler.py + daemon/ws_publish.py + daemon/upload.py + daemon/static_sync.py + daemon/ws_messages.py", $descr="Persistent /ws/daemon client, proxy response handling, typed broadcasts/notify_host, upload handoff, and static sync trigger.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.TrainingDaemon.Sessionpersistence, "Session persistence", $techn="daemon/session_state.py + daemon/persisted_models.py", $descr="Persists global-state.json, session-state.json, session metadata, key points, and slide manifests.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.TrainingDaemon.DebateAIcleanup, "Debate AI cleanup", $techn="daemon/debate/ai_cleanup.py + daemon/llm/adapter.py", $descr="Claude-backed argument dedupe, cleanup, and new-suggestion generation.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.TrainingDaemon.Codereviewsmartpaste, "Code-review smart paste", $techn="daemon/codereview/router.py + daemon/llm/adapter.py", $descr="Claude Haiku call that extracts a code snippet and language from pasted LLM output.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.TrainingDaemon.Summaryhelpers, "Summary helpers", $techn="daemon/summary/loop.py", $descr="File-driven helpers that read ai-summary.md and surface its mtime; consumed by misc routes and host snapshots.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.TrainingDaemon.Slidesanduploadpipeline, "Slides and upload pipeline", $techn="daemon/slides/*", $descr="Loads catalogs, tracks current slide, converts decks, invalidates Railway cache, scans PPTX mtimes, and pushes slide metadata/files.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.TrainingDaemon.Addonsbridge, "Addons bridge", $techn="daemon/addon_bridge_client.py + daemon/adapters/*", $descr="Receives slide events and slides_viewed deltas from victor-macos-addons and forwards emoji/session notifications back.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.TrainingDaemon.Transcriptingest, "Transcript ingest", $techn="daemon/transcript/*", $descr="Loads normalized transcript files, tracks deltas, and exposes range queries used by quizzes and host inspection.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.TrainingDaemon.MaterialsRAGindexer, "Materials RAG indexer", $techn="daemon/rag/*", $descr="Background ChromaDB indexer over local workshop materials; retriever helpers available for future consumers.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.TrainingDaemon.Emailnotifications, "Email notifications", $techn="daemon/email_notify.py", $descr="Best-effort AgentMail-backed notifications for participant paste/feedback events.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.TrainingDaemon.Daemontelemetry, "Daemon telemetry", $techn="daemon/telemetry/*", $descr="OpenTelemetry tracer provider, file span exporter, and FastAPI/urllib instrumentation; also reused by the Railway process.", $tags="", $link="")
    Component(WorkshopLiveInteractionTool.TrainingDaemon.Lockandheartbeat, "Lock and heartbeat", $techn="daemon/lock.py", $descr="Single-instance PID lock and heartbeat maintenance.", $tags="", $link="")
  }

  Container(WorkshopLiveInteractionTool.HostSPA, "Host SPA", $techn="HTML/CSS/JavaScript", $descr="Host control panel served from the daemon host server on localhost.", $tags="", $link="")
  Container(WorkshopLiveInteractionTool.RailwayBackend, "Railway Backend", $techn="Python 3.12 / FastAPI / Uvicorn", $descr="Thin session-aware bridge for participants, slides, uploads, daemon sync, inbox webhooks, and telemetry.", $tags="", $link="")
}

Rel(WorkshopLiveInteractionTool.TrainingDaemon.Embeddedhostserver, WorkshopLiveInteractionTool.TrainingDaemon.ParticipantAPIs, "Mounts", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.Embeddedhostserver, WorkshopLiveInteractionTool.TrainingDaemon.HostAPIs, "Mounts", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.Embeddedhostserver, WorkshopLiveInteractionTool.TrainingDaemon.Pollqueue, "Mounts host poll-queue routes", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.Embeddedhostserver, WorkshopLiveInteractionTool.RailwayBackend, "Proxies unmatched HTTP and WebSocket traffic to", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.ParticipantAPIs, WorkshopLiveInteractionTool.TrainingDaemon.Runtimestatemodules, "Mutates", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.ParticipantAPIs, WorkshopLiveInteractionTool.TrainingDaemon.Railwaybridge, "Publishes participant updates through", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.ParticipantAPIs, WorkshopLiveInteractionTool.TrainingDaemon.Sessionpersistence, "Reads current session metadata from", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.ParticipantAPIs, WorkshopLiveInteractionTool.TrainingDaemon.Codereviewsmartpaste, "Triggers Claude smart-paste extraction (host create path)", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.HostAPIs, WorkshopLiveInteractionTool.TrainingDaemon.Runtimestatemodules, "Mutates", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.HostAPIs, WorkshopLiveInteractionTool.TrainingDaemon.Railwaybridge, "Publishes host-driven updates through", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.HostAPIs, WorkshopLiveInteractionTool.TrainingDaemon.Sessionpersistence, "Persists and restores session files through", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.HostAPIs, WorkshopLiveInteractionTool.TrainingDaemon.Slidesanduploadpipeline, "Triggers", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.HostAPIs, WorkshopLiveInteractionTool.TrainingDaemon.DebateAIcleanup, "Triggers", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.HostAPIs, WorkshopLiveInteractionTool.TrainingDaemon.Summaryhelpers, "Reads ai-summary.md state through", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.HostAPIs, WorkshopLiveInteractionTool.TrainingDaemon.Pollqueue, "Manages queued poll questions through", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.Runtimestatemodules, WorkshopLiveInteractionTool.TrainingDaemon.Sessionpersistence, "Is snapshotted by", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.Railwaybridge, WorkshopLiveInteractionTool.RailwayBackend, "Connects over /ws/daemon and host-auth REST", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.Railwaybridge, WorkshopLiveInteractionTool.TrainingDaemon.Sessionpersistence, "Reads session metadata for sync payloads from", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.DebateAIcleanup, AnthropicClaudeAPI, "Requests cleanup suggestions from", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.DebateAIcleanup, WorkshopLiveInteractionTool.TrainingDaemon.Railwaybridge, "Publishes cleanup results through", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.Codereviewsmartpaste, AnthropicClaudeAPI, "Requests code/language extraction from", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.Summaryhelpers, Hostsessionfiles, "Reads ai-summary.md and mtime from", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.Slidesanduploadpipeline, Hostsessionfiles, "Reads slide catalogs and generated PDFs from", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.Slidesanduploadpipeline, WorkshopLiveInteractionTool.TrainingDaemon.Railwaybridge, "Publishes slide metadata/files through", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.Slidesanduploadpipeline, WorkshopLiveInteractionTool.RailwayBackend, "Uses cache and upload helpers on", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.Addonsbridge, victormacosaddons, "Connects over local WebSocket", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.Addonsbridge, WorkshopLiveInteractionTool.TrainingDaemon.Slidesanduploadpipeline, "Forwards slide events to", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.Addonsbridge, WorkshopLiveInteractionTool.TrainingDaemon.Railwaybridge, "Forwards emoji/session notifications through", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.Transcriptingest, Hostsessionfiles, "Reads normalized transcript files from", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.MaterialsRAGindexer, Hostsessionfiles, "Reads local materials from", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.MaterialsRAGindexer, LocalChromaDBstore, "Writes embeddings into", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.Emailnotifications, AgentMail, "Sends notification emails via AgentMail SDK", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.TrainingDaemon.ParticipantAPIs, WorkshopLiveInteractionTool.TrainingDaemon.Emailnotifications, "Triggers paste/feedback notifications through", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.RailwayBackend, AgentMail, "Receives signed AgentMail webhooks for incoming Claude email", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.HostSPA, WorkshopLiveInteractionTool.TrainingDaemon.Embeddedhostserver, "Loads host pages and local APIs", $techn="", $tags="", $link="")
Rel(WorkshopLiveInteractionTool.RailwayBackend, WorkshopLiveInteractionTool.TrainingDaemon.Daemontelemetry, "Configures OTel tracing and FastAPI instrumentation through (Railway side)", $techn="", $tags="", $link="")

SHOW_LEGEND(true)
hide stereotypes
@enduml